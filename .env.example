# Application & Security
APP_NAME="KRA Reconciliation API"
APP_VERSION="1.0.0"
SECRET_KEY="generate_a_random_64_char_secret_key_for_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Connection
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/kra_reconciliation"
POSTGRES_DB="kra_reconciliation"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="secure_postgres_password"

# CORS Configuration
CORS_ORIGINS="http://localhost:3000,https://app.yourdomain.com"

# Optional SAP Service Layer Defaults
# SAP_BASE_URL="https://sap-server.company.com:50000/b1s/v1"
# SAP_USERNAME="manager"
# SAP_PASSWORD="sap_password"
# SAP_COMPANY_DB="SBODEMOKENYA"
# SAP_VERIFY_SSL="true"

# Frontend Public API URL
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
